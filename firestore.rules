rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Seller scope id can be either the Firebase UID or a business seller id stored in custom claims
    function isSellerScopeId(id) {
      return isAuthenticated() && (
        id == request.auth.uid ||
        id == request.auth.token.ecommerceId ||
        id == request.auth.token.ecomId
      );
    }
    
    function hasRole(role) {
      return isAuthenticated() && (
        request.auth.token.role == role || 
        (request.auth.token.roles is list && role in request.auth.token.roles)
      );
    }
    
    // Liste des emails admin de confiance (bypass custom claims)
    function isAdminEmail() {
      return isAuthenticated() && request.auth.token.email in [
        'sasouare@gmail.com'
      ];
    }
    
    function isAdmin() {
      return hasRole('admin') || isAdminEmail();
    }
    
    // Check user doc for role (fallback when custom claims not set)
    function hasRoleInDoc(role) {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }
    
    function isSeller() {
      return hasRole('ecommerce') || hasRoleInDoc('ecommerce') || isAdmin();
    }
    
    function isCourier() {
      return hasRole('courier') || isAdmin();
    }
    
    function isCloser() {
      return hasRole('closer') || isAdmin();
    }
    
    // ============================================
    // USERS COLLECTION
    // ============================================
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // Permettre la création si l'utilisateur crée son propre document
      // isOwner vérifie que request.auth.uid == userId
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }
    
    // ============================================
    // PRODUCTS COLLECTION
    // ============================================
    match /products/{productId} {
      // Anyone can read active products; sellers can read their own; admin reads all
      allow read: if resource.data.status == 'active'
                  || isAdmin()
                  || isSeller()
                  || isSellerScopeId(resource.data.sellerId);
      
      // Admin can create any product; sellers can create products under their own scope id
      allow create: if isAdmin()
                    || isSellerScopeId(request.resource.data.sellerId);
      
      // Admin can update any product; owners can update their own
      allow update: if isAdmin()
                    || isSellerScopeId(resource.data.sellerId);
      
      // Admin can delete any; owners can delete their own
      allow delete: if isAdmin()
                    || isSellerScopeId(resource.data.sellerId);
    }
    
    // ============================================
    // ORDERS COLLECTION
    // ============================================
    match /orders/{orderId} {
      // Customers, sellers, closers, couriers can read relevant orders; admin reads all
      allow read: if isAdmin()
                  || isOwner(resource.data.customerId) 
                  || (isSeller() && request.auth.token.ecommerceId in resource.data.sellerIds)
                  || (isCloser() && resource.data.assignedCloser == request.auth.uid)
                  || (isCourier() && resource.data.assignedCourier == request.auth.uid);
      
      // Authenticated users can create their own orders; admin can create any
      allow create: if isAdmin()
                    || (isAuthenticated() && request.resource.data.customerId == request.auth.uid);
      
      // Admin can update any order
      allow update: if isAdmin()
              || (isAuthenticated() && request.auth.uid in resource.data.sellerIds);
      allow delete: if false;
    }
    
    // ============================================
    // ECOMMERCES COLLECTION (Sellers)
    // ============================================
    match /ecommerces/{ecommerceId} {
      // Admin can read/write all; sellers can read/update their own
      allow read: if isAdmin() || (isSeller() && request.auth.token.ecommerceId == ecommerceId);
      allow create: if isAdmin();
      allow update: if isAdmin() || (isSeller() && request.auth.token.ecommerceId == ecommerceId);
      allow delete: if isAdmin();
    }
    
    // ============================================
    // WALLETS COLLECTION
    // ============================================
    match /wallets/{userId} {
      // Users can only read their own wallet
      allow read: if isOwner(userId) || isAdmin();
      
      // Wallet modifications only via Cloud Functions (transactions atomiques)
      // CRITICAL: Ne jamais permettre l'écriture directe pour éviter la fraude
      allow create, update, delete: if false;
    }
    
    // ============================================
    // TRANSACTIONS COLLECTION
    // ============================================
    match /transactions/{txId} {
      // Users can read their own transactions
      allow read: if isOwner(resource.data.userId) || isAdmin();
      
      // Transactions created only via Cloud Functions
      allow create, update, delete: if false;
    }
    
    // ============================================
    // PAYMENTS COLLECTION
    // ============================================
    match /payments/{paymentId} {
      allow read: if isOwner(resource.data.customerId) || isAdmin();
      allow create: if isAdmin()
                    || (isAuthenticated() && request.resource.data.customerId == request.auth.uid);
      allow update, delete: if false;
    }
    
    // ============================================
    // PAYOUTS COLLECTION (Seller payouts audit)
    // ============================================
    match /payouts/{payoutId} {
      allow read: if isAdmin() || 
                  (isSeller() && request.auth.token.ecommerceId in resource.data.sellers);
      allow create, update, delete: if false;
    }
    
    // ============================================
    // WITHDRAWALS COLLECTION
    // ============================================
    match /withdrawals/{withdrawalId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      // Users can create withdrawal requests
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Only Cloud Functions can update/delete
      allow update, delete: if false;
    }
    
    // ============================================
    // INVESTOR PAYOUTS COLLECTION
    // ============================================
    match /investor_payouts/{payoutId} {
      allow read: if isOwner(resource.data.investorId) || isAdmin();
      allow create, update, delete: if false;
    }
    
    // ============================================
    // INVESTMENTS COLLECTION
    // ============================================
    match /investments/{investmentId} {
      allow read: if isOwner(resource.data.investorId) || isAdmin();
      allow create, update, delete: if false;
    }
    
    // ============================================
    // WEBHOOK LOGS (Admin only)
    // ============================================
    match /webhook_logs/{logId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }
    
    // ============================================
    // DELIVERIES COLLECTION
    // ============================================
    match /deliveries/{missionId} {
      allow read: if isOwner(resource.data.customerId)
                  || (isCourier() && (resource.data.assignedCourier == request.auth.uid || resource.data.status == 'pending'))
                  || isAdmin();
      allow create, update, delete: if false;
    }
    
    // ============================================
    // ACADEMY & ENROLLMENTS
    // ============================================
    match /academy/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /enrollments/{enrollmentId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create, update, delete: if false;
    }
    
    // ============================================
    // NOTIFICATIONS
    // ============================================
    match /notifications/{notifId} {
      allow read: if isOwner(resource.data.userId);
      allow update: if isOwner(resource.data.userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create, delete: if false;
    }
    
    // ============================================
    // REVIEWS COLLECTION
    // ============================================
    match /reviews/{reviewId} {
      // Anyone can read approved reviews; admin reads all
      allow read: if resource.data.status == 'approved' || isAdmin() || isOwner(resource.data.userId);
      
      // Authenticated users can create reviews for products they may have purchased
      allow create: if isAuthenticated() 
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.rating >= 1 
                    && request.resource.data.rating <= 5
                    && request.resource.data.comment is string
                    && request.resource.data.comment.size() <= 1000;
      
      // Users can update their own pending reviews; admin can update any (moderation)
      allow update: if isAdmin() 
                    || (isOwner(resource.data.userId) && resource.data.status == 'pending');
      
      // Only admin can delete reviews
      allow delete: if isAdmin();
    }
    
    // ============================================
    // CONFIG COLLECTION (Admin only — API keys, SMTP)
    // ============================================
    match /config/{configId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    // ============================================
    // MAIL COLLECTION (Trigger Email Extension)
    // ============================================
    match /mail/{mailId} {
      allow read: if isAdmin();
      // Admin can create (resend emails); Cloud Functions also write here
      allow create: if isAdmin();
      // Admin can update _resendCount on original emails
      allow update: if isAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['_resendCount', '_lastResendAt']);
      allow delete: if false;
    }
    
    // ============================================
    // SELLER ORDERS (seller sub-references)
    // ============================================
    match /seller_orders/{docId} {
      allow read: if isAdmin() || (isSeller() && resource.data.sellerId == request.auth.uid);
      allow create, update, delete: if false;
    }
    
    // ============================================
    // ANALYTICS EVENTS (Cloud Functions only)
    // ============================================
    match /analytics_events/{eventId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }
    
    // ============================================
    // CARTS COLLECTION
    // ============================================
    match /carts/{userId} {
      allow read, write: if isOwner(userId);
      allow delete: if isOwner(userId) || isAdmin();
    }
    
    // ============================================
    // CLOSERS COLLECTION
    // ============================================
    match /closers/{closerId} {
      allow read: if isAdmin() || isCloser();
      allow create, update, delete: if false;
    }
    
    // ============================================
    // COURIERS COLLECTION
    // ============================================
    match /couriers/{courierId} {
      allow read: if isAdmin() || (isCourier() && resource.data.userId == request.auth.uid);
      allow update: if isCourier() && resource.data.userId == request.auth.uid;
      allow create, delete: if false;
    }
    
    // ============================================
    // SELLER SETTINGS (owner-only)
    // ============================================
    match /seller_settings/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isSeller();
      allow update: if isOwner(userId) && isSeller();
      allow delete: if isAdmin();
    }
  }
}
